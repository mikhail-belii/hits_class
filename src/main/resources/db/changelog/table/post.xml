<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="CreatePostTable" author="KBelovodchenko">
        <createTable tableName="post">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_post"/>
            </column>
            <column name="text" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
            <column name="course_id" type="UUID"/>
            <column name="author_id" type="UUID"/>
            <column name="post_type" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="deadline" type="DATETIME"/>
            <column name="max_score" type="INT"/>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="author_id"
                                 baseTableName="post"
                                 constraintName="FK_POST_ON_AUTHOR"
                                 referencedColumnNames="id"
                                 referencedTableName="user"/>

        <addForeignKeyConstraint baseColumnNames="course_id"
                                 baseTableName="post"
                                 constraintName="FK_POST_ON_COURSE"
                                 referencedColumnNames="id"
                                 referencedTableName="course"/>
    </changeSet>

</databaseChangeLog>